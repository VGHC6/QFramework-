      "locked": false,
      "text": "为了优化交互逻辑，防止后续交互逻辑太多导致controller臃肿，引入Command",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "为了优化交互逻辑，防止后续交互逻辑太多导致controller臃肿，引入Command",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "hkbIQ-6_jvFKsPq3QvCE8",
      "type": "text",
      "x": 2058.8020832150464,
      "y": 3927.7961025902764,
      "width": 960.000000000004,
      "height": 33.33333333333348,
      "angle": 0,
