      ],
      "updated": 1783070871671,
      "link": null,
      "locked": false,
      "text": "  public class CounterViewController : MonoBehaviour\n    {\n        void Start()\n        {\n            // 注册\n            CounterModel.Count.OnValueChanged += OnCountChanged;\n\n            transform.Find(\"BtnAdd\").GetComponent<Button>()\n                .onClick.AddListener(() =>\n                {\n                    // 交互逻辑：这个会自动触发表现逻辑\n                    CounterModel.Count.Value++;\n                });\n\n            transform.Find(\"BtnSub\").GetComponent<Button>()\n                .onClick.AddListener(() =>\n                {\n                    // 交互逻辑：这个会自动触发表现逻辑\n                    CounterModel.Count.Value--;\n                });\n            \n            OnCountChanged(CounterModel.Count.Value);\n        }\n\n        // 表现逻辑\n        private void OnCountChanged(int newValue)\n        {\n            transform.Find(\"CountText\").GetComponent<Text>().text = newValue.ToString();\n        }\n\n        private void OnDestroy()\n        {\n            // 注销\n            CounterModel.Count.OnValueChanged -= OnCountChanged;\n        }\n    }\n\n    public static class CounterModel\n    {\n        public static BindableProperty<int> Count = new BindableProperty<int>()\n        {\n            Value = 0\n        };\n    }\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  public class CounterViewController : MonoBehaviour\n    {\n        void Start()\n        {\n            // 注册\n            CounterModel.Count.OnValueChanged += OnCountChanged;\n\n            transform.Find(\"BtnAdd\").GetComponent<Button>()\n                .onClick.AddListener(() =>\n                {\n                    // 交互逻辑：这个会自动触发表现逻辑\n                    CounterModel.Count.Value++;\n                });\n\n            transform.Find(\"BtnSub\").GetComponent<Button>()\n                .onClick.AddListener(() =>\n                {\n                    // 交互逻辑：这个会自动触发表现逻辑\n                    CounterModel.Count.Value--;\n                });\n            \n            OnCountChanged(CounterModel.Count.Value);\n        }\n\n        // 表现逻辑\n        private void OnCountChanged(int newValue)\n        {\n            transform.Find(\"CountText\").GetComponent<Text>().text = newValue.ToString();\n        }\n\n        private void OnDestroy()\n        {\n            // 注销\n            CounterModel.Count.OnValueChanged -= OnCountChanged;\n        }\n    }\n\n    public static class CounterModel\n    {\n        public static BindableProperty<int> Count = new BindableProperty<int>()\n        {\n            Value = 0\n        };\n    }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
