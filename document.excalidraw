    {
      "id": "70PJUKl1mxPQKADzVMRLW",
      "type": "text",
      "x": 2038.5163689293327,
      "y": 3447.4230867172605,
      "width": 758.9864288330072,
      "height": 264.99999999999994,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
