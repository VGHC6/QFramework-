      "text": "交互逻辑：View -> Model\n表现逻辑: Model -> View",
      "fontSize": 33.142857142857075,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "交互逻辑：View -> Model\n表现逻辑: Model -> View",
