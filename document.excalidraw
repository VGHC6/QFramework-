      "text": "   public class CounterViewController : MonoBehaviour\n    {\n        private CounterModel mCounterModel;\n        \n        void Start()\n        {\n            // 获取\n            mCounterModel = CounterApp.Get<CounterModel>();\n            \n            // 注册\n            mCounterModel.Count.OnValueChanged += OnCountChanged;\n\n            transform.Find(\"BtnAdd\").GetComponent<Button>()\n                .onClick.AddListener(() =>\n                {\n                    // 交互逻辑\n                    new AddCountCommand()\n                        .Execute();\n                });\n\n            transform.Find(\"BtnSub\").GetComponent<Button>()\n                .onClick.AddListener(() =>\n                {\n                    // 交互逻辑\n                    new SubCountCommand()\n                        .Execute();\n                });\n            \n            OnCountChanged(mCounterModel.Count.Value);\n        }\n\n        // 表现逻辑\n        private void OnCountChanged(int newValue)\n        {\n            transform.Find(\"CountText\").GetComponent<Text>().text = newValue.ToString();\n        }\n\n        private void OnDestroy()\n        {\n            // 注销\n            mCounterModel.Count.OnValueChanged -= OnCountChanged;\n\n            mCounterModel = null;\n        }\n    }\n\n    /// <summary>\n    /// 不需要是单例了\n    /// </summary>\n    public class CounterModel\n    {\n        public BindableProperty<int> Count = new BindableProperty<int>()\n        {\n            Value = 0\n        };\n    }\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "   public class CounterViewController : MonoBehaviour\n    {\n        private CounterModel mCounterModel;\n        \n        void Start()\n        {\n            // 获取\n            mCounterModel = CounterApp.Get<CounterModel>();\n            \n            // 注册\n            mCounterModel.Count.OnValueChanged += OnCountChanged;\n\n            transform.Find(\"BtnAdd\").GetComponent<Button>()\n                .onClick.AddListener(() =>\n                {\n                    // 交互逻辑\n                    new AddCountCommand()\n                        .Execute();\n                });\n\n            transform.Find(\"BtnSub\").GetComponent<Button>()\n                .onClick.AddListener(() =>\n                {\n                    // 交互逻辑\n                    new SubCountCommand()\n                        .Execute();\n                });\n            \n            OnCountChanged(mCounterModel.Count.Value);\n        }\n\n        // 表现逻辑\n        private void OnCountChanged(int newValue)\n        {\n            transform.Find(\"CountText\").GetComponent<Text>().text = newValue.ToString();\n        }\n\n        private void OnDestroy()\n        {\n            // 注销\n            mCounterModel.Count.OnValueChanged -= OnCountChanged;\n\n            mCounterModel = null;\n        }\n    }\n\n    /// <summary>\n    /// 不需要是单例了\n    /// </summary>\n    public class CounterModel\n    {\n        public BindableProperty<int> Count = new BindableProperty<int>()\n        {\n            Value = 0\n        };\n    }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
