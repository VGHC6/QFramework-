      "link": null,
      "locked": false,
      "text": " public class CounterViewController : MonoBehaviour\n    {\n        void Start()\n        {\n            // 注册\n            CounterModel.Instance.Count.OnValueChanged += OnCountChanged;\n\n            transform.Find(\"BtnAdd\").GetComponent<Button>()\n                .onClick.AddListener(() =>\n                {\n                    // 交互逻辑\n                    new AddCountCommand()\n                        .Execute();\n                });\n\n            transform.Find(\"BtnSub\").GetComponent<Button>()\n                .onClick.AddListener(() =>\n                {\n                    // 交互逻辑\n                    new SubCountCommand()\n                        .Execute();\n                });\n            \n            OnCountChanged(CounterModel.Instance.Count.Value);\n        }\n\n        // 表现逻辑\n        private void OnCountChanged(int newValue)\n        {\n            transform.Find(\"CountText\").GetComponent<Text>().text = newValue.ToString();\n        }\n\n        private void OnDestroy()\n        {\n            // 注销\n            CounterModel.Instance.Count.OnValueChanged -= OnCountChanged;\n        }\n    }\n\n    public class CounterModel : Singleton<CounterModel>\n    {\n        // 需要声明一个非 Public 构造\n        private CounterModel(){}\n        \n        public BindableProperty<int> Count = new BindableProperty<int>()\n        {\n            Value = 0\n        };\n    }",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": " public class CounterViewController : MonoBehaviour\n    {\n        void Start()\n        {\n            // 注册\n            CounterModel.Instance.Count.OnValueChanged += OnCountChanged;\n\n            transform.Find(\"BtnAdd\").GetComponent<Button>()\n                .onClick.AddListener(() =>\n                {\n                    // 交互逻辑\n                    new AddCountCommand()\n                        .Execute();\n                });\n\n            transform.Find(\"BtnSub\").GetComponent<Button>()\n                .onClick.AddListener(() =>\n                {\n                    // 交互逻辑\n                    new SubCountCommand()\n                        .Execute();\n                });\n            \n            OnCountChanged(CounterModel.Instance.Count.Value);\n        }\n\n        // 表现逻辑\n        private void OnCountChanged(int newValue)\n        {\n            transform.Find(\"CountText\").GetComponent<Text>().text = newValue.ToString();\n        }\n\n        private void OnDestroy()\n        {\n            // 注销\n            CounterModel.Instance.Count.OnValueChanged -= OnCountChanged;\n        }\n    }\n\n    public class CounterModel : Singleton<CounterModel>\n    {\n        // 需要声明一个非 Public 构造\n        private CounterModel(){}\n        \n        public BindableProperty<int> Count = new BindableProperty<int>()\n        {\n            Value = 0\n        };\n    }",
      "autoResize": true,
      "lineHeight": 1.25
    },
