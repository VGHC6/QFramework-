      "lineHeight": 1.25
    },
    {
      "id": "jUgRgA8GoTjA7GQB-Ycax",
      "type": "text",
      "x": 2001.9647816277484,
      "y": 328.22864227281343,
      "width": 1064,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
