    {
      "id": "-Jt0PdldvISoCvQUf1Xcf",
      "type": "text",
      "x": 2051.6235117864776,
      "y": 2473.6572137013864,
      "width": 577.2796630859375,
      "height": 475,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ax",
      "roundness": null,
      "seed": 1289339369,
      "version": 34,
      "versionNonce": 232786375,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "Ei8foBidj61OF_dRcozsW",
          "type": "arrow"
        }
      ],
      "updated": 1783072596213,
      "link": null,
      "locked": false,
      "text": "public class BindableProperty<T> where T : IEquatable<T>\n    {\n        private T mValue;\n\n        public T Value\n        {\n            get => mValue;\n            set\n            {\n                if (!mValue.Equals(value))\n                {\n                    mValue = value;\n                    OnValueChanged?.Invoke(value);\n                }\n            }\n        }\n\n        public Action<T> OnValueChanged;\n    }",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public class BindableProperty<T> where T : IEquatable<T>\n    {\n        private T mValue;\n\n        public T Value\n        {\n            get => mValue;\n            set\n            {\n                if (!mValue.Equals(value))\n                {\n                    mValue = value;\n                    OnValueChanged?.Invoke(value);\n                }\n            }\n        }\n\n        public Action<T> OnValueChanged;\n    }",
      "autoResize": true,
      "lineHeight": 1.25
    },
