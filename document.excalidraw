      "type": "text",
      "x": 2049.0163689293354,
      "y": 2119.419118463291,
      "width": 1099.3026931564298,
      "height": 26.428571428571093,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
