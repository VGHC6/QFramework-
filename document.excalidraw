      "versionNonce": 616863433,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783067369892,
      "link": null,
      "locked": false,
      "text": "重构Event",
      "fontSize": 23.200000000000003,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "重构Event",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "hAZ0oAyYhmlw73_9E9oYM",
      "type": "text",
      "x": 2035.2981149610823,
      "y": 416.22864227281343,
      "width": 513.0596923828125,
      "height": 725,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ae",
      "roundness": null,
      "seed": 51318407,
      "version": 77,
      "versionNonce": 393794985,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783067369892,
      "link": null,
      "locked": false,
      "text": "public class Event<T> where T : Event<T>\n    {\n        private static Action mOnEventTrigger;\n\n        /// <summary>\n        /// 注册事件\n        /// </summary>\n        public static void Register(Action onEvent)\n        {\n            mOnEventTrigger += onEvent;\n        }\n\n        /// <summary>\n        /// 注销事件\n        /// </summary>\n        /// <param name=\"onEvent\"></param>\n        public static void UnRegister(Action onEvent)\n        {\n            mOnEventTrigger -= onEvent;\n        }\n\n        /// <summary>\n        /// 触发事件\n        /// </summary>\n        public static void Trigger()\n        {\n            mOnEventTrigger?.Invoke();\n        }\n    }",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public class Event<T> where T : Event<T>\n    {\n        private static Action mOnEventTrigger;\n\n        /// <summary>\n        /// 注册事件\n        /// </summary>\n        public static void Register(Action onEvent)\n        {\n            mOnEventTrigger += onEvent;\n        }\n\n        /// <summary>\n        /// 注销事件\n        /// </summary>\n        /// <param name=\"onEvent\"></param>\n        public static void UnRegister(Action onEvent)\n        {\n            mOnEventTrigger -= onEvent;\n        }\n\n        /// <summary>\n        /// 触发事件\n        /// </summary>\n        public static void Trigger()\n        {\n            mOnEventTrigger?.Invoke();\n        }\n    }",
      "autoResize": true,
      "lineHeight": 1.25
    },
