      "text": "解决了静态类识别度不高的问题",
      "fontSize": 33.33333333333321,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "解决了静态类识别度不高的问题",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LVrHrlWfbfAubLTUWwELp",
      "type": "text",
      "x": 5462.238591151555,
      "y": 1275.3913406855188,
      "width": 1020.75927734375,
      "height": 675,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b12",
      "roundness": null,
      "seed": 820060105,
      "version": 75,
      "versionNonce": 2007673511,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783072889786,
      "link": null,
      "locked": false,
      "text": "public class Singleton<T> where T : class\n    {\n        public static T Instance\n        {\n            get\n            {\n                if (mInstance == null)\n                {\n                    // 通过反射获取构造\n                    var ctors = typeof(T).GetConstructors(BindingFlags.Instance | BindingFlags.NonPublic);\n                    // 获取无参非 public 的构造\n                    var ctor = Array.Find(ctors, c => c.GetParameters().Length == 0);\n\n                    if (ctor == null)\n                    {\n                        throw new Exception(\"Non-Public Constructor() not found in \" + typeof(T));\n                    }\n\n                    mInstance = ctor.Invoke(null) as T;\n                }\n\n                return mInstance;\n            }\n        }\n\n        private static T mInstance;\n    }",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public class Singleton<T> where T : class\n    {\n        public static T Instance\n        {\n            get\n            {\n                if (mInstance == null)\n                {\n                    // 通过反射获取构造\n                    var ctors = typeof(T).GetConstructors(BindingFlags.Instance | BindingFlags.NonPublic);\n                    // 获取无参非 public 的构造\n                    var ctor = Array.Find(ctors, c => c.GetParameters().Length == 0);\n\n                    if (ctor == null)\n                    {\n                        throw new Exception(\"Non-Public Constructor() not found in \" + typeof(T));\n                    }\n\n                    mInstance = ctor.Invoke(null) as T;\n                }\n\n                return mInstance;\n            }\n        }\n\n        private static T mInstance;\n    }",
      "autoResize": true,
      "lineHeight": 1.25
    },
