      "boundElements": null,
      "updated": 1783073496205,
      "link": null,
      "locked": false,
      "text": "IOC 容器，理解为是一个字典，这个字典以 Type 为 key，以对象即 Instance 为 value",
      "fontSize": 34.22222222222191,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "IOC 容器，理解为是一个字典，这个字典以 Type 为 key，以对象即 Instance 为 value",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "kXERNtnFq6Jwh3lWWKaFK",
      "type": "text",
      "x": 5517.68979200448,
      "y": 2324.944842586986,
      "width": 821.6795043945312,
      "height": 1075,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1W",
      "roundness": null,
      "seed": 1665023815,
      "version": 76,
      "versionNonce": 755052487,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "1RoyLSqtkjgDOPUy8Bnrp",
          "type": "arrow"
        }
      ],
      "updated": 1783075043168,
      "link": null,
      "locked": false,
      "text": "public class IOCContainer\n    {\n        /// <summary>\n        /// 实例\n        /// </summary>\n        public Dictionary<Type, object> mInstances = new Dictionary<Type, object>();\n\n        /// <summary>\n        /// 注册\n        /// </summary>\n        /// <param name=\"instance\"></param>\n        /// <typeparam name=\"T\"></typeparam>\n        public void Register<T>(T instance)\n        {\n            var key = typeof(T);\n\n            if (mInstances.ContainsKey(key))\n            {\n                mInstances[key] = instance;\n            }\n            else\n            {\n                mInstances.Add(key,instance);\n            }\n        }\n\n        /// <summary>\n        /// 获取\n        /// </summary>\n        public T  Get<T>() where T : class\n        {\n            var key = typeof(T);\n            \n            object retObj;\n            \n            if(mInstances.TryGetValue(key,out retObj))\n            {\n                return retObj as T;\n            }\n\n            return null;\n        }\n    }",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "public class IOCContainer\n    {\n        /// <summary>\n        /// 实例\n        /// </summary>\n        public Dictionary<Type, object> mInstances = new Dictionary<Type, object>();\n\n        /// <summary>\n        /// 注册\n        /// </summary>\n        /// <param name=\"instance\"></param>\n        /// <typeparam name=\"T\"></typeparam>\n        public void Register<T>(T instance)\n        {\n            var key = typeof(T);\n\n            if (mInstances.ContainsKey(key))\n            {\n                mInstances[key] = instance;\n            }\n            else\n            {\n                mInstances.Add(key,instance);\n            }\n        }\n\n        /// <summary>\n        /// 获取\n        /// </summary>\n        public T  Get<T>() where T : class\n        {\n            var key = typeof(T);\n            \n            object retObj;\n            \n            if(mInstances.TryGetValue(key,out retObj))\n            {\n                return retObj as T;\n            }\n\n            return null;\n        }\n    }",
      "autoResize": true,
      "lineHeight": 1.25
    },
