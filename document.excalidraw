      "updated": 1783072405590,
      "link": null,
      "locked": false,
      "text": "public struct AddCountCommand : ICommand\n    {\n        public void Execute()\n        {\n            CounterModel.Instance.Count.Value++;\n        }\n    }",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
