    {
      "id": "RS4mzemZxi6DubIM-JgM0",
      "type": "text",
      "x": 5516.297211724852,
      "y": 2267.9410589085005,
      "width": 1349.142390950508,
      "height": 42.77777777777739,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
