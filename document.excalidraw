        }
      ],
      "updated": 1783070630376,
      "link": null,
      "locked": false,
      "text": "public struct AddCountCommand : ICommand\n    {\n        public void Execute()\n        {\n            CounterModel.Count.Value++;\n        }\n    }",
      "fontSize": 20,
      "fontFamily": 5,
