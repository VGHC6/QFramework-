    {
      "id": "Jm6N_IIILnF_zDLKsc8FL",
      "type": "text",
      "x": 7156.761497439158,
      "y": 2646.111017116182,
      "width": 514.5796508789062,
      "height": 675,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
